---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.page-banner {
				background: linear-gradient(180deg, #daedfb 0%, #f0e8f0 70%, var(--basin-blue-100) 100%);
				padding: 2.5em 0 0;
				overflow: hidden;
			}
			.banner-inner {
				max-width: 760px;
				margin: 0 auto;
				padding: 0 2em 1.5em;
			}
			.banner-inner h1 {
				font-family: 'Cormorant Garamond', serif;
				font-style: italic;
				font-size: 2.2em;
				color: var(--basin-ink);
				margin: 0.2em 0 0;
			}
			.date {
				font-family: 'Quicksand', sans-serif;
				font-size: 0.82em;
				color: var(--basin-pink-500);
			}
			.wave {
				display: block;
				width: 100%;
				height: 32px;
			}
			main {
				max-width: 760px;
				margin: 0 auto;
				padding: 2em 2em 4em;
			}
			.prose {
				color: var(--basin-ink-soft);
				line-height: 1.8;
			}
		</style>
	</head>

	<body>
		<Header />
		<div class="page-banner">
			<div class="banner-inner">
				<div class="date"><FormattedDate date={pubDate} /></div>
				<h1>{title}</h1>
			</div>
			<svg class="wave" viewBox="0 0 1200 40" preserveAspectRatio="none" aria-hidden="true">
				<path d="M0,20 C200,38 400,4 600,20 C800,36 1000,6 1200,20 L1200,40 L0,40 Z" fill="var(--basin-blue-100)"></path>
			</svg>
		</div>
		<main>
			<article>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
