---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`The Current · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="page-banner">
			<div class="banner-inner">
				<span class="page-label">The Current</span>
				<p class="page-sub">Everything that flows through the basin.</p>
			</div>
			<svg class="wave" viewBox="0 0 1200 40" preserveAspectRatio="none" aria-hidden="true">
				<path d="M0,20 C200,38 400,4 600,20 C800,36 1000,6 1200,20 L1200,40 L0,40 Z" fill="var(--basin-blue-100)"></path>
			</svg>
		</div>
		<main>
			<ul>
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						<span class="date"><FormattedDate date={post.data.pubDate} /></span>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-banner {
		background: linear-gradient(180deg, #daedfb 0%, #f0e8f0 70%, var(--basin-blue-100) 100%);
		padding: 2.5em 0 0;
		overflow: hidden;
	}
	.banner-inner {
		max-width: 760px;
		margin: 0 auto;
		padding: 0 2em 1.5em;
	}
	.page-label {
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		font-size: 2.2em;
		font-weight: 600;
		color: var(--basin-ink);
	}
	.page-sub {
		font-family: 'Quicksand', sans-serif;
		font-size: 0.85em;
		color: var(--basin-ink-mute);
		margin: 0.2em 0 0;
	}
	.wave {
		display: block;
		width: 100%;
		height: 32px;
	}
	main {
		max-width: 760px;
		margin: 0 auto;
		padding: 1.5em 2em 4em;
	}
	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	ul li {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 1em 0;
		border-bottom: 1px solid var(--basin-pink-200);
		gap: 1em;
	}
	ul li a {
		font-family: 'Quicksand', sans-serif;
		font-weight: 500;
		font-size: 1.02em;
		color: var(--basin-ink);
		text-decoration: none;
	}
	ul li a:hover { color: var(--basin-pink-500); }
	.date {
		font-family: 'Quicksand', sans-serif;
		font-size: 0.82em;
		color: var(--basin-pink-500);
		white-space: nowrap;
	}
</style>
