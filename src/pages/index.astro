---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<!-- decorative heart (top-right) -->
				<svg class="deco deco-heart" width="72" height="66" viewBox="0 0 86 78" aria-hidden="true">
					<path d="M14 26 C10 12, 28 4, 38 16 C40 19, 42 22, 43 24 C44 22, 46 19, 48 16 C58 3, 78 10, 76 26 C73 44, 50 60, 43 66 C36 60, 17 46, 14 26 Z" fill="none" stroke="#ffffff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
				<!-- sparkle 1 -->
				<svg class="deco deco-spark1" width="18" height="18" viewBox="0 0 22 22" aria-hidden="true">
					<path d="M11 1 C11 7, 13 9, 21 11 C13 13, 11 15, 11 21 C11 15, 9 13, 1 11 C9 9, 11 7, 11 1 Z" fill="#ffffff"></path>
				</svg>
				<!-- sparkle 2 -->
				<svg class="deco deco-spark2" width="12" height="12" viewBox="0 0 22 22" aria-hidden="true">
					<path d="M11 1 C11 7, 13 9, 21 11 C13 13, 11 15, 11 21 C11 15, 9 13, 1 11 C9 9, 11 7, 11 1 Z" fill="#ffffff"></path>
				</svg>

				<div class="otter-row">
					<div class="otter">🦦</div>
					<span class="kicker">A small basin on the internet</span>
				</div>

				<h1>Welcome to the <em>Basin</em>.</h1>

				<p class="lede">
					This is Mr.O's Basin. Ousmanek is a 17-year-old from Taipei who just moved to Seattle.
					He writes about what he reads, what he learns, and whatever else catches his attention —
					NBA, AI, Supercell games, life abroad.
				</p>

				<!-- soft wave divider -->
				<svg class="wave" viewBox="0 0 1200 56" preserveAspectRatio="none" aria-hidden="true">
					<path d="M0,30 C150,54 300,8 450,30 C600,52 750,8 900,30 C1050,52 1140,16 1200,28 L1200,56 L0,56 Z" fill="var(--basin-blue-50)"></path>
				</svg>
			</section>

			<section class="recent">
				<h2 class="recent-label">Recent ripples</h2>
				<ul>
					{posts.map(post => (
						<li>
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
						</li>
					))}
				</ul>
				<a href="/blog" class="all-posts">All ripples →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 760px;
		margin: 0 auto;
		padding: 0 1em 3em;
	}

	/* Hero — soft blue→pink water surface */
	.hero {
		position: relative;
		margin: 0 -1em;
		padding: 3em 2em 0.5em;
		background: linear-gradient(180deg, #daedfb 0%, #f5ecf1 65%, var(--basin-blue-50) 100%);
		border-radius: 0;
		overflow: hidden;
	}
	@media (min-width: 720px) {
		.hero { border-radius: 18px; margin: 1em 0 0; }
	}

	.deco { position: absolute; }
	.deco-heart  { top: 38px;  right: 50px; opacity: .9; }
	.deco-spark1 { top: 34px;  right: 158px; }
	.deco-spark2 { top: 124px; right: 130px; }

	.otter-row {
		position: relative;
		display: flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 1.2em;
	}
	.otter {
		width: 54px; height: 54px;
		border-radius: 50%;
		background: var(--basin-pink-50);
		display: flex; align-items: center; justify-content: center;
		font-size: 30px; line-height: 1;
		animation: basinBob 6s ease-in-out infinite;
	}
	@keyframes basinBob {
		0%, 100% { transform: translateY(0); }
		50%      { transform: translateY(-6px); }
	}
	.kicker {
		font-family: 'Quicksand', sans-serif;
		font-size: 0.72em;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--basin-pink-500);
	}

	.hero h1 {
		position: relative;
		margin: 0 0 0.5em;
		font-family: 'Cormorant Garamond', serif;
		font-weight: 600;
		font-size: 2.4em;
		line-height: 1.15;
		color: var(--basin-ink);
	}
	.hero h1 em {
		color: var(--basin-pink-500);
		font-style: italic;
	}

	.lede {
		position: relative;
		max-width: 560px;
		margin: 0 0 2.6em;
		font-family: 'Quicksand', sans-serif;
		font-size: 1em;
		line-height: 1.85;
		color: var(--basin-ink-soft);
	}

	.wave {
		display: block;
		width: calc(100% + 4em);
		height: 44px;
		margin: 0 -2em -0.5em;
	}

	/* Recent ripples */
	.recent { padding: 2em 1em 0; }
	.recent-label {
		font-family: 'Quicksand', sans-serif;
		font-size: 0.72em;
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--basin-pink-500);
		margin: 0 0 0.4em;
	}
	.recent ul {
		list-style: none;
		padding: 0;
		margin: 0 0 1em;
	}
	.recent ul li {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0.95em 0;
		border-bottom: 1px solid var(--basin-pink-200);
		gap: 1em;
	}
	.recent ul li a {
		font-family: 'Quicksand', 'Noto Serif TC', sans-serif;
		font-weight: 500;
		font-size: 1.02em;
		color: var(--basin-ink);
		text-decoration: none;
	}
	.recent ul li a:hover { color: var(--basin-pink-500); }
	.date {
		font-family: 'Quicksand', sans-serif;
		font-size: 0.82em;
		color: var(--basin-pink-500);
		white-space: nowrap;
	}
	.all-posts {
		display: inline-block;
		margin-top: 0.6em;
		font-family: 'Quicksand', sans-serif;
		font-weight: 700;
		font-size: 0.9em;
		color: var(--basin-pink-500);
		text-decoration: none;
	}
	.all-posts:hover { color: var(--basin-pink-600); }

	@media (max-width: 720px) {
		.hero { padding: 2em 1.4em 0.5em; }
		.deco-heart { width: 56px; height: 50px; right: 24px; top: 28px; }
		.deco-spark1 { right: 96px; top: 30px; }
		.deco-spark2 { right: 80px; top: 96px; }
		.hero h1 { font-size: 2em; }
	}
</style>
