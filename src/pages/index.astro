---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p>
					This is Mr.O's Basin. Ousmanek is a 17-year-old from Taipei who just moved to Seattle.
					He writes about what he reads, what he learns, and whatever else catches his attention —
					NBA, AI stuff, Supercell games, life abroad. No fixed schedule. Updated when there's
					something worth saying.
				</p>
			</section>

			<section class="recent">
				<h2>Recent</h2>
				<ul>
					{posts.map(post => (
						<li>
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
						</li>
					))}
				</ul>
				<a href="/blog" class="all-posts">All posts →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 680px;
		margin: 0 auto;
		padding: 2em 1em 4em;
	}
	.intro {
		margin-bottom: 3em;
	}
	.intro p {
		font-size: 1.05em;
		line-height: 1.7;
		color: rgb(var(--gray-dark));
	}
	.recent h2 {
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
		margin-bottom: 1em;
	}
	.recent ul {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5em;
	}
	.recent ul li {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0.5em 0;
		border-bottom: 1px solid rgb(var(--gray-light));
		gap: 1em;
	}
	.recent ul li a {
		text-decoration: none;
		color: rgb(var(--black));
	}
	.recent ul li a:hover {
		text-decoration: underline;
	}
	.date {
		font-size: 0.85em;
		color: rgb(var(--gray));
		white-space: nowrap;
	}
	.all-posts {
		font-size: 0.9em;
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.all-posts:hover {
		color: rgb(var(--gray-dark));
	}
</style>
